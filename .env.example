# Browser runtime (required)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Script/runtime verification (optional but recommended for full checks)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Supabase Edge Function secrets for send-email (set in Supabase secrets)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_ADDRESS=no-reply@example.com

# Cloudflare R2 / media delivery (set in Supabase secrets for media edge functions)
CF_ACCOUNT_ID=your_cloudflare_account_id
CF_R2_BUCKET=lub-media-originals
CF_R2_ACCESS_KEY_ID=your_r2_access_key_id
CF_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
CF_R2_S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
CF_MEDIA_PUBLIC_BASE_URL=https://media.lub.org.in
